<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="OldFashionedMaker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:OldFashionedMaker.Pages"
    Title="Old Fashioned Maker"
    Shell.BackgroundColor="#2C1810"
    Shell.ForegroundColor="#D4A574"
    Shell.TitleColor="#D4A574"
    FlyoutBehavior="Disabled">

    <ShellContent
        ContentTemplate="{DataTemplate pages:ChatPage}"
        Route="chat" />

</Shell>
