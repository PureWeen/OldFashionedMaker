<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OldFashionedMaker.Pages.SearchPage"
             Title="🔍 Search">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20" RowSpacing="12">

        <Label Text="Flavor Search" FontSize="24" FontAttributes="Bold" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Entry x:Name="SearchEntry" Placeholder="e.g. smoky and not too sweet"
                   ReturnCommand="{x:Null}" ReturnType="Search" />
            <Button Grid.Column="1" Text="🔍" Clicked="OnSearchClicked"
                    BackgroundColor="#D4A574" TextColor="White" WidthRequest="50" />
        </Grid>

        <VerticalStackLayout Grid.Row="2" x:Name="ResultsContainer">
            <Label x:Name="StatusLabel" TextColor="Gray" Margin="0,8"
                   Text="Search your drinks by flavor description using AI embeddings" />
            <CollectionView x:Name="ResultsCollection" SelectionMode="Single"
                            SelectionChanged="OnResultSelected">
                <CollectionView.EmptyView>
                    <Label />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Padding="12"
                               StrokeShape="RoundRectangle 8"
                               Stroke="#D4A574" BackgroundColor="#FDF6EE">
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                <Label Text="{Binding Drink.Bourbon}" FontAttributes="Bold" FontSize="16" />
                                <Label Grid.Column="1" Text="{Binding ScoreText}" FontSize="12"
                                       TextColor="#8B6914" FontAttributes="Bold" />
                                <Label Grid.Row="1" Grid.ColumnSpan="2"
                                       Text="{Binding Drink.RecipeSummary}"
                                       FontSize="12" TextColor="Gray" LineBreakMode="TailTruncation" />
                                <Label Grid.Row="2" Grid.ColumnSpan="2" FontSize="12" Margin="0,2,0,0"
                                       Text="{Binding Drink.TastingNotes}" TextColor="Gray"
                                       LineBreakMode="TailTruncation" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
