<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OldFashionedMaker.Pages.ChatPage"
             Title="🥃 Old Fashioned Maker">

    <Grid RowDefinitions="*,Auto">

        <!-- Chat messages area -->
        <ScrollView x:Name="ChatScroll" Grid.Row="0" Padding="12,8">
            <VerticalStackLayout x:Name="MessageStack" Spacing="6" />
        </ScrollView>

        <!-- Input bar -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8"
              Padding="12,8" BackgroundColor="#3D2517">
            <Button x:Name="MicButton" Grid.Column="0" Text="🎙️"
                    BackgroundColor="#4A3228"
                    TextColor="White"
                    FontSize="18"
                    WidthRequest="44" HeightRequest="44" />
            <Entry x:Name="MessageEntry" Grid.Column="1"
                   Placeholder="Talk to your bartender..."
                   TextColor="White"
                   BackgroundColor="#4A3228"
                   FontSize="15"
                   ReturnType="Send" />
            <Button x:Name="SendButton" Grid.Column="2" Text="Send"
                    BackgroundColor="#D4A574"
                    TextColor="White"
                    FontSize="15"
                    HeightRequest="44" />
        </Grid>

    </Grid>

</ContentPage>
