<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OldFashionedMaker.Pages.DrinkDetailPage"
             Title="Drink Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label x:Name="TitleLabel" FontSize="24" FontAttributes="Bold" />
            <Label x:Name="DateLabel" TextColor="Gray" />
            <BoxView HeightRequest="1" Color="#D4A574" Margin="0,4" />

            <!-- Recipe Details -->
            <Label Text="Recipe" FontSize="18" FontAttributes="Bold" />
            <Label x:Name="RecipeLabel" FontSize="14" />

            <Label Text="Rating" FontSize="18" FontAttributes="Bold" Margin="0,8,0,0" />
            <Label x:Name="RatingLabel" FontSize="20" />

            <Label Text="Your Notes" FontSize="18" FontAttributes="Bold" Margin="0,8,0,0" />
            <Label x:Name="NotesLabel" FontSize="14" TextColor="Gray" />

            <!-- AI Tasting Notes -->
            <BoxView HeightRequest="1" Color="#D4A574" Margin="0,8" />
            <Label Text="🤖 AI Tasting Notes" FontSize="18" FontAttributes="Bold" />
            <Label x:Name="AINotesLabel" FontSize="14" TextColor="Gray"
                   Text="Tap below to generate AI tasting notes" />
            <Button x:Name="GenerateNotesBtn" Text="✨ Generate Tasting Notes"
                    Clicked="OnGenerateNotesClicked"
                    BackgroundColor="#8B6914" TextColor="White" />

            <!-- AI Advice -->
            <BoxView HeightRequest="1" Color="#D4A574" Margin="0,8" />
            <Label Text="🧠 AI Advice" FontSize="18" FontAttributes="Bold" />
            <Label x:Name="AdviceLabel" FontSize="14" TextColor="Gray"
                   Text="Tap below to get advice on improving this drink" />
            <Button x:Name="GetAdviceBtn" Text="💡 Improve My Drink"
                    Clicked="OnGetAdviceClicked"
                    BackgroundColor="#D4A574" TextColor="White" />

            <!-- Delete -->
            <Button x:Name="DeleteBtn" Text="🗑️ Delete Drink"
                    Clicked="OnDeleteClicked"
                    BackgroundColor="#CC4444" TextColor="White" Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
