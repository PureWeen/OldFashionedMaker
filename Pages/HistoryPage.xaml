<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OldFashionedMaker.Pages.HistoryPage"
             Title="📋 History">

    <Grid RowDefinitions="Auto,*" Padding="20">

        <Label Text="Your Old Fashioneds" FontSize="24" FontAttributes="Bold" />

        <CollectionView x:Name="DrinksCollection" Grid.Row="1"
                        SelectionMode="Single" SelectionChanged="OnDrinkSelected">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label Text="🥃" FontSize="48" HorizontalTextAlignment="Center" />
                    <Label Text="No drinks logged yet" FontSize="18"
                           HorizontalTextAlignment="Center" TextColor="Gray" />
                    <Label Text="Head to the Log tab to record your first Old Fashioned!"
                           HorizontalTextAlignment="Center" TextColor="Gray" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,6" Padding="14"
                           StrokeShape="RoundRectangle 10"
                           Stroke="#D4A574" BackgroundColor="#FDF6EE">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                            <Label Text="{Binding Bourbon}" FontSize="16" FontAttributes="Bold" />
                            <Label Grid.Column="1" FontSize="14" TextColor="Gray">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding CreatedAt, StringFormat='{0:MMM dd, h:mm tt}'}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding RecipeSummary}"
                                   FontSize="12" TextColor="Gray" LineBreakMode="TailTruncation" />
                            <Label Grid.Row="2" Grid.ColumnSpan="2" FontSize="14" Margin="0,4,0,0">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Rating: " />
                                        <Span Text="{Binding Rating, StringFormat='{0}/5 ⭐'}" FontAttributes="Bold" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
