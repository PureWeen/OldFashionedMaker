<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OldFashionedMaker.Views.DrinkCardView">
    <Border Padding="14" Margin="4,6"
            StrokeShape="RoundRectangle 12"
            Stroke="#D4A574" BackgroundColor="#FDF6EE"
            MaximumWidthRequest="500"
            HorizontalOptions="Start">
        <VerticalStackLayout Spacing="4">
            <Label x:Name="TitleLabel" FontSize="16" FontAttributes="Bold" TextColor="#2C1810" />
            <Label x:Name="RecipeLabel" FontSize="12" TextColor="#8B6914" />
            <Label x:Name="RatingLabel" FontSize="14" />
            <Label x:Name="NotesLabel" FontSize="12" TextColor="Gray"
                   LineBreakMode="WordWrap" IsVisible="False" />
        </VerticalStackLayout>
    </Border>
</ContentView>
